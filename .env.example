# MongoDB CSFLE Multi-Tenancy Demo - Environment Variables
# Copy this file to .env and customize as needed
# Docker Compose will automatically load variables from .env file

# ============================================================================
# OPTION 1: Use Local MongoDB Container (Default)
# ============================================================================
# Uncomment these lines to use the MongoDB container defined in docker-compose.yml
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=fle_demo
MONGODB_KEYVAULT_NAMESPACE=fle_demo.__keyVault

# Local Master Key Path (for manual setup)
# For Docker, this is set in docker-compose.yml to /app/keys/local_master_key.bin
MONGODB_LOCAL_MASTER_KEY_PATH=./local_master_key.bin

# ============================================================================
# OPTION 2: Use MongoDB Atlas (Production)
# ============================================================================
# Uncomment and configure these lines to use MongoDB Atlas
# When using Atlas, you can comment out the 'mongodb' service in docker-compose.yml
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DATABASE=fle_demo
# MONGODB_KEYVAULT_NAMESPACE=fle_demo.__keyVault

# Connection Pool Settings (for Atlas)
MONGODB_POOL_MAX_SIZE=20
MONGODB_POOL_MIN_SIZE=2

# ============================================================================
# Spring Boot Configuration
# ============================================================================
# Spring Boot Configuration
# For Docker: SPRING_PROFILES_ACTIVE=docker
# For manual setup: Comment out or set to 'default'
#SPRING_PROFILES_ACTIVE=docker

# ============================================================================
# Backend Port Configuration
# ============================================================================
# Change this if port 8080 is already in use on your machine
BACKEND_PORT=8080

# ============================================================================
# Frontend Configuration
# ============================================================================
# Update this if you change BACKEND_PORT above
VITE_API_BASE_URL=http://localhost:8080

